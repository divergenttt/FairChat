# ── Shared / documentation only — copy to service-specific env in Vercel / Railway ──

# ── Railway (api-server) ─────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/fairchat?sslmode=require
JWT_SECRET=generate-a-long-random-string-min-32-chars
# Comma-separated browser origins (Vercel preview + production)
FRONTEND_URL=https://your-app.vercel.app
ALLOWED_ORIGINS=https://your-app.vercel.app,https://*.vercel.app
# Upload storage (ephemeral on Railway unless you attach a volume or S3)
DATA_DIR=/data
STORAGE_ADAPTER=local
MAX_UPLOAD_SIZE_MB=10
# S3_BUCKET=
# S3_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# Optional admin seed on first boot
# SEED_ADMIN_PASSWORD=
LOG_LEVEL=info

# ── Vercel (fairchat) — Build ────────────────────────────────────────────────
# Proxies /api/* to Railway (see artifacts/fairchat/vercel.ts)
API_SERVER_URL=https://your-app.up.railway.app

# ── Vercel (fairchat) — Runtime (Vite, baked into the bundle) ──────────────
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_cloud_project_id
# Required when API is on another host and you skip Vercel /api rewrites:
# VITE_API_URL=https://your-app.up.railway.app
# Required on Vercel: WebSocket cannot be proxied — point at Railway directly
VITE_WS_URL=wss://your-app.up.railway.app
